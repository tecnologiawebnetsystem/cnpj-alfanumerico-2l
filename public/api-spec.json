{
  "openapi": "3.0.3",
  "info": {
    "title": "CNPJ Alfanumérico API",
    "description": "API completa para análise e correção de campos CNPJ em repositórios de código e bancos de dados. Sistema multi-perfil com gestão de tarefas, integrações com Azure DevOps/GitHub e chatbot inteligente.",
    "version": "2.0.0",
    "contact": {
      "name": "Suporte CNPJ Alfanumérico",
      "email": "suporte@cnpj-alfa.com"
    },
    "license": {
      "name": "Proprietário",
      "url": "https://cnpj-alfa.com/license"
    }
  },
  "servers": [
    {
      "url": "https://api.cnpj-alfa.com",
      "description": "Servidor de Produção"
    },
    {
      "url": "http://localhost:3000",
      "description": "Desenvolvimento Local"
    }
  ],
  "tags": [
    {
      "name": "Autenticação",
      "description": "Endpoints de login, logout e gerenciamento de sessão"
    },
    {
      "name": "Super Admin",
      "description": "Endpoints exclusivos para Super Administradores (gestão global)"
    },
    {
      "name": "Admin Cliente",
      "description": "Endpoints para Administradores de Cliente (gestão do próprio cliente)"
    },
    {
      "name": "Desenvolvedor",
      "description": "Endpoints para Desenvolvedores (visualização e execução de tarefas)"
    },
    {
      "name": "Análises",
      "description": "Criação e gerenciamento de análises de repositórios"
    },
    {
      "name": "Tarefas",
      "description": "Gestão completa de tarefas de correção CNPJ"
    },
    {
      "name": "Relatórios",
      "description": "Geração e exportação de relatórios analíticos"
    },
    {
      "name": "Integrações",
      "description": "Configuração de integrações (GitHub, Azure DevOps, GitLab)"
    },
    {
      "name": "Chatbot",
      "description": "Chatbot inteligente de assistência"
    },
    {
      "name": "Analytics",
      "description": "Métricas e estatísticas do sistema"
    },
    {
      "name": "Notificações",
      "description": "Sistema de notificações em tempo real"
    },
    {
      "name": "Desenvolvedores",
      "description": "Gestão de desenvolvedores do cliente"
    }
  ],
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": ["Autenticação"],
        "summary": "Autenticar usuário",
        "description": "Realiza login no sistema com email e senha. Retorna token JWT e informações do usuário.",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "admin@empresa.com"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "SenhaSegura123!"
                  },
                  "twoFactorCode": {
                    "type": "string",
                    "description": "Código 2FA (se habilitado)",
                    "example": "123456"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login realizado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["Autenticação"],
        "summary": "Obter usuário atual",
        "description": "Retorna informações do usuário autenticado atualmente",
        "operationId": "getCurrentUser",
        "security": [{"BearerAuth": []}],
        "responses": {
          "200": {
            "description": "Dados do usuário",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/admin/clients": {
      "get": {
        "tags": ["Super Admin"],
        "summary": "Listar todos os clientes",
        "description": "Retorna lista completa de clientes cadastrados (apenas Super Admin)",
        "operationId": "listClients",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {"type": "integer", "default": 1}
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {"type": "integer", "default": 20}
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de clientes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "clients": {
                      "type": "array",
                      "items": {"$ref": "#/components/schemas/Client"}
                    },
                    "total": {"type": "integer"},
                    "page": {"type": "integer"},
                    "totalPages": {"type": "integer"}
                  }
                }
              }
            }
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      },
      "post": {
        "tags": ["Super Admin"],
        "summary": "Criar novo cliente",
        "description": "Cria um novo cliente no sistema com licença e configurações",
        "operationId": "createClient",
        "security": [{"BearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateClientRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Cliente criado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Client"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/api/admin/clients/{id}": {
      "put": {
        "tags": ["Super Admin"],
        "summary": "Atualizar cliente",
        "description": "Atualiza informações de um cliente específico",
        "operationId": "updateClient",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string", "format": "uuid"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateClientRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cliente atualizado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Client"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "tags": ["Super Admin"],
        "summary": "Excluir cliente",
        "description": "Remove um cliente e todos os seus dados do sistema",
        "operationId": "deleteClient",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string", "format": "uuid"}
          }
        ],
        "responses": {
          "204": {
            "description": "Cliente excluído com sucesso"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/analyze": {
      "post": {
        "tags": ["Análises", "Admin Cliente"],
        "summary": "Iniciar nova análise",
        "description": "Inicia análise de repositório para detectar campos CNPJ que precisam de correção",
        "operationId": "startAnalysis",
        "security": [{"BearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartAnalysisRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Análise iniciada com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Analysis"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/analyses/{id}": {
      "delete": {
        "tags": ["Análises", "Admin Cliente"],
        "summary": "Excluir análise",
        "description": "Remove uma análise e todas as suas tarefas associadas",
        "operationId": "deleteAnalysis",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string", "format": "uuid"}
          }
        ],
        "responses": {
          "204": {
            "description": "Análise excluída com sucesso"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/analyses/{id}/progress": {
      "get": {
        "tags": ["Análises"],
        "summary": "Obter progresso da análise",
        "description": "Retorna status e progresso em tempo real da análise",
        "operationId": "getAnalysisProgress",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string", "format": "uuid"}
          }
        ],
        "responses": {
          "200": {
            "description": "Progresso da análise",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalysisProgress"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/tasks": {
      "get": {
        "tags": ["Tarefas"],
        "summary": "Listar tarefas",
        "description": "Retorna lista de tarefas com filtros e paginação",
        "operationId": "listTasks",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["pendente", "em_progresso", "concluida", "cancelada"]
            }
          },
          {
            "name": "priority",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["baixa", "media", "alta", "critica"]
            }
          },
          {
            "name": "assignee_id",
            "in": "query",
            "schema": {"type": "string", "format": "uuid"}
          },
          {
            "name": "repository",
            "in": "query",
            "schema": {"type": "string"}
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de tarefas",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Task"}
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Tarefas", "Admin Cliente"],
        "summary": "Criar nova tarefa",
        "description": "Cria uma tarefa manual de correção CNPJ",
        "operationId": "createTask",
        "security": [{"BearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTaskRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tarefa criada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          }
        }
      }
    },
    "/api/tasks/{id}": {
      "put": {
        "tags": ["Tarefas"],
        "summary": "Atualizar tarefa",
        "description": "Atualiza informações de uma tarefa (status, prioridade, assignee)",
        "operationId": "updateTask",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string", "format": "uuid"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTaskRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tarefa atualizada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Task"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Tarefas", "Admin Cliente"],
        "summary": "Excluir tarefa",
        "description": "Remove uma tarefa do sistema",
        "operationId": "deleteTask",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string", "format": "uuid"}
          }
        ],
        "responses": {
          "204": {
            "description": "Tarefa excluída"
          }
        }
      }
    },
    "/api/tasks/{id}/apply": {
      "post": {
        "tags": ["Tarefas", "Desenvolvedor"],
        "summary": "Aplicar correção automaticamente",
        "description": "Aplica a correção CNPJ no repositório (cria branch, commit e PR)",
        "operationId": "applyTaskFix",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string", "format": "uuid"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["method"],
                "properties": {
                  "method": {
                    "type": "string",
                    "enum": ["pr", "commit", "copy"],
                    "description": "Método de aplicação: PR (recomendado), commit direto ou copiar código"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Correção aplicada",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {"type": "boolean"},
                    "pr_url": {"type": "string", "format": "uri"},
                    "branch_name": {"type": "string"},
                    "commit_sha": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/tasks/azure-devops": {
      "post": {
        "tags": ["Tarefas", "Integrações"],
        "summary": "Sincronizar tarefa com Azure DevOps",
        "description": "Cria Work Item no Azure Boards para uma tarefa",
        "operationId": "syncTaskToAzure",
        "security": [{"BearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["task_id", "integration_id"],
                "properties": {
                  "task_id": {"type": "string", "format": "uuid"},
                  "integration_id": {"type": "string", "format": "uuid"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sincronização realizada",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "work_item_id": {"type": "integer"},
                    "work_item_url": {"type": "string", "format": "uri"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/client/developers": {
      "get": {
        "tags": ["Desenvolvedores", "Admin Cliente"],
        "summary": "Listar desenvolvedores",
        "description": "Retorna lista de desenvolvedores do cliente",
        "operationId": "listDevelopers",
        "security": [{"BearerAuth": []}],
        "responses": {
          "200": {
            "description": "Lista de desenvolvedores",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {"$ref": "#/components/schemas/Developer"}
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Desenvolvedores", "Admin Cliente"],
        "summary": "Criar desenvolvedor",
        "description": "Adiciona um novo desenvolvedor ao cliente",
        "operationId": "createDeveloper",
        "security": [{"BearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDeveloperRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Desenvolvedor criado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Developer"
                }
              }
            }
          }
        }
      }
    },
    "/api/client/developers/{id}": {
      "delete": {
        "tags": ["Desenvolvedores", "Admin Cliente"],
        "summary": "Excluir desenvolvedor",
        "description": "Remove um desenvolvedor do cliente",
        "operationId": "deleteDeveloper",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "string", "format": "uuid"}
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["user_id"],
                "properties": {
                  "user_id": {"type": "string", "format": "uuid"}
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Desenvolvedor excluído"
          }
        }
      }
    },
    "/api/admin/cleanup-developer-tasks": {
      "post": {
        "tags": ["Tarefas", "Admin Cliente"],
        "summary": "Limpar tarefas de desenvolvedor",
        "description": "Remove todas as tarefas atribuídas a um desenvolvedor específico",
        "operationId": "cleanupDeveloperTasks",
        "security": [{"BearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["developer_id"],
                "properties": {
                  "developer_id": {"type": "string", "format": "uuid"},
                  "preview": {
                    "type": "boolean",
                    "default": false,
                    "description": "Se true, retorna contagem sem excluir"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resultado da limpeza",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "deleted_tasks": {"type": "integer"},
                    "deleted_progress": {"type": "integer"},
                    "deleted_history": {"type": "integer"},
                    "deleted_comments": {"type": "integer"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/cleanup-client-tasks": {
      "post": {
        "tags": ["Tarefas", "Admin Cliente"],
        "summary": "Limpar TODAS as tarefas do cliente",
        "description": "Remove todas as tarefas do cliente (independente de desenvolvedor ou repositório)",
        "operationId": "cleanupClientTasks",
        "security": [{"BearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["client_id"],
                "properties": {
                  "client_id": {"type": "string", "format": "uuid"},
                  "preview": {
                    "type": "boolean",
                    "default": false
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resultado da limpeza",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "deleted_tasks": {"type": "integer"},
                    "deleted_progress": {"type": "integer"},
                    "deleted_history": {"type": "integer"},
                    "deleted_comments": {"type": "integer"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/reports/generate": {
      "get": {
        "tags": ["Relatórios", "Admin Cliente"],
        "summary": "Gerar relatório de análise",
        "description": "Gera relatório completo com todas as correções necessárias",
        "operationId": "generateReport",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "analysis_id",
            "in": "query",
            "required": true,
            "schema": {"type": "string", "format": "uuid"}
          },
          {
            "name": "format",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["json", "pdf", "csv"],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Relatório gerado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Report"
                }
              },
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        }
      }
    },
    "/api/chatbot": {
      "post": {
        "tags": ["Chatbot"],
        "summary": "Enviar mensagem ao chatbot",
        "description": "Interage com o chatbot inteligente para consultar tarefas e obter assistência",
        "operationId": "chatbotMessage",
        "security": [{"BearerAuth": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["message", "user_id"],
                "properties": {
                  "message": {
                    "type": "string",
                    "example": "Minhas tarefas pendentes"
                  },
                  "user_id": {"type": "string", "format": "uuid"},
                  "session_id": {"type": "string", "format": "uuid"}
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resposta do chatbot",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "reply": {"type": "string"},
                    "session_id": {"type": "string"},
                    "intent": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Chatbot"],
        "summary": "Obter histórico do chat",
        "description": "Retorna histórico de conversas do usuário",
        "operationId": "getChatHistory",
        "security": [{"BearerAuth": []}],
        "parameters": [
          {
            "name": "session_id",
            "in": "query",
            "schema": {"type": "string", "format": "uuid"}
          }
        ],
        "responses": {
          "200": {
            "description": "Histórico de conversas",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "message": {"type": "string"},
                      "reply": {"type": "string"},
                      "timestamp": {"type": "string", "format": "date-time"}
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
