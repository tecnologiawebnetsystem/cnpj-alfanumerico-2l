  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token JWT obtido via endpoint /api/auth/login"
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Não autorizado - Token inválido ou ausente",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {"type": "string", "example": "Não autorizado"}
              }
            }
          }
        }
      },
      "Forbidden": {
        "description": "Acesso negado - Permissão insuficiente",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {"type": "string", "example": "Acesso negado"}
              }
            }
          }
        }
      },
      "NotFound": {
        "description": "Recurso não encontrado",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {"type": "string", "example": "Recurso não encontrado"}
              }
            }
          }
        }
      },
      "BadRequest": {
        "description": "Requisição inválida",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {"type": "string"},
                "details": {"type": "array", "items": {"type": "string"}}
              }
            }
          }
        }
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "email": {"type": "string", "format": "email"},
          "name": {"type": "string"},
          "role": {
            "type": "string",
            "enum": ["super_admin", "admin", "developer"]
          },
          "client_id": {"type": "string", "format": "uuid"},
          "created_at": {"type": "string", "format": "date-time"}
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "user": {"$ref": "#/components/schemas/User"},
          "token": {"type": "string"},
          "expires_at": {"type": "string", "format": "date-time"}
        }
      },
      "Client": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "name": {"type": "string"},
          "cnpj": {"type": "string"},
          "license_expires_at": {"type": "string", "format": "date-time"},
          "is_active": {"type": "boolean"},
          "created_at": {"type": "string", "format": "date-time"}
        }
      },
      "CreateClientRequest": {
        "type": "object",
        "required": ["name", "cnpj", "admin_email", "admin_password"],
        "properties": {
          "name": {"type": "string", "example": "Empresa XYZ Ltda"},
          "cnpj": {"type": "string", "example": "12.345.678/0001-90"},
          "admin_email": {"type": "string", "format": "email"},
          "admin_password": {"type": "string", "format": "password"},
          "license_days": {"type": "integer", "default": 365}
        }
      },
      "UpdateClientRequest": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "is_active": {"type": "boolean"}
        }
      },
      "Analysis": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "client_id": {"type": "string", "format": "uuid"},
          "repository": {"type": "string"},
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "failed"]
          },
          "findings_count": {"type": "integer"},
          "created_at": {"type": "string", "format": "date-time"},
          "completed_at": {"type": "string", "format": "date-time"}
        }
      },
      "StartAnalysisRequest": {
        "type": "object",
        "required": ["integration_id", "repositories"],
        "properties": {
          "integration_id": {"type": "string", "format": "uuid"},
          "repositories": {
            "type": "array",
            "items": {"type": "string"},
            "example": ["repo-frontend", "repo-backend"]
          },
          "include_database": {"type": "boolean", "default": false}
        }
      },
      "AnalysisProgress": {
        "type": "object",
        "properties": {
          "status": {"type": "string"},
          "progress_percentage": {"type": "number", "minimum": 0, "maximum": 100},
          "current_step": {"type": "string"},
          "findings_count": {"type": "integer"},
          "estimated_completion": {"type": "string", "format": "date-time"}
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "analysis_id": {"type": "string", "format": "uuid"},
          "client_id": {"type": "string", "format": "uuid"},
          "repository": {"type": "string"},
          "file_path": {"type": "string"},
          "line_number": {"type": "integer"},
          "current_code": {"type": "string"},
          "suggested_code": {"type": "string"},
          "status": {
            "type": "string",
            "enum": ["pendente", "em_progresso", "concluida", "cancelada"]
          },
          "priority": {
            "type": "string",
            "enum": ["baixa", "media", "alta", "critica"]
          },
          "assignee_id": {"type": "string", "format": "uuid"},
          "external_id": {"type": "string", "description": "ID do Work Item no Azure DevOps"},
          "external_url": {"type": "string", "format": "uri"},
          "created_at": {"type": "string", "format": "date-time"},
          "updated_at": {"type": "string", "format": "date-time"}
        }
      },
      "CreateTaskRequest": {
        "type": "object",
        "required": ["repository", "file_path", "line_number", "current_code", "suggested_code"],
        "properties": {
          "repository": {"type": "string"},
          "file_path": {"type": "string"},
          "line_number": {"type": "integer"},
          "current_code": {"type": "string"},
          "suggested_code": {"type": "string"},
          "priority": {"type": "string", "default": "media"},
          "assignee_id": {"type": "string", "format": "uuid"}
        }
      },
      "UpdateTaskRequest": {
        "type": "object",
        "properties": {
          "status": {"type": "string"},
          "priority": {"type": "string"},
          "assignee_id": {"type": "string", "format": "uuid"}
        }
      },
      "Developer": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "name": {"type": "string"},
          "email": {"type": "string", "format": "email"},
          "client_id": {"type": "string", "format": "uuid"},
          "tasks_count": {"type": "integer"},
          "completed_tasks_count": {"type": "integer"},
          "is_active": {"type": "boolean"}
        }
      },
      "CreateDeveloperRequest": {
        "type": "object",
        "required": ["name", "email", "password"],
        "properties": {
          "name": {"type": "string"},
          "email": {"type": "string", "format": "email"},
          "password": {"type": "string", "format": "password"}
        }
      },
      "Report": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "analysis_id": {"type": "string", "format": "uuid"},
          "total_findings": {"type": "integer"},
          "by_repository": {"type": "object"},
          "by_priority": {"type": "object"},
          "by_status": {"type": "object"},
          "generated_at": {"type": "string", "format": "date-time"}
        }
      },
      "Integration": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "client_id": {"type": "string", "format": "uuid"},
          "provider": {
            "type": "string",
            "enum": ["github", "azure_devops", "gitlab", "bitbucket"]
          },
          "name": {"type": "string"},
          "organization": {"type": "string"},
          "project": {"type": "string", "description": "Projeto Azure DevOps (opcional)"},
          "is_active": {"type": "boolean"},
          "created_at": {"type": "string", "format": "date-time"}
        }
      },
      "CreateIntegrationRequest": {
        "type": "object",
        "required": ["provider", "name", "token"],
        "properties": {
          "provider": {"type": "string"},
          "name": {"type": "string"},
          "token": {"type": "string"},
          "organization": {"type": "string"},
          "project": {"type": "string", "description": "Projeto Azure DevOps"}
        }
      },
      "Notification": {
        "type": "object",
        "properties": {
          "id": {"type": "string", "format": "uuid"},
          "user_id": {"type": "string", "format": "uuid"},
          "title": {"type": "string"},
          "message": {"type": "string"},
          "type": {
            "type": "string",
            "enum": ["info", "success", "warning", "error"]
          },
          "read": {"type": "boolean"},
          "created_at": {"type": "string", "format": "date-time"}
        }
      },
      "TaskAnalytics": {
        "type": "object",
        "properties": {
          "total_tasks": {"type": "integer"},
          "by_status": {
            "type": "object",
            "properties": {
              "pendente": {"type": "integer"},
              "em_progresso": {"type": "integer"},
              "concluida": {"type": "integer"},
              "cancelada": {"type": "integer"}
            }
          },
          "by_priority": {
            "type": "object",
            "properties": {
              "baixa": {"type": "integer"},
              "media": {"type": "integer"},
              "alta": {"type": "integer"},
              "critica": {"type": "integer"}
            }
          },
          "completion_rate": {"type": "number"},
          "average_completion_time_days": {"type": "number"},
          "by_developer": {"type": "array"}
        }
      }
    }
  },
  "security": [
    {"BearerAuth": []}
  ]
}
