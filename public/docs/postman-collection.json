              "raw": "{{baseUrl}}/analyses/:id",
              "host": ["{{baseUrl}}"],
              "path": ["analyses", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "uuid-da-analise"
                }
              ]
            }
          }
        },
        {
          "name": "Progresso da Análise",
          "request": {
            "method": "GET",
