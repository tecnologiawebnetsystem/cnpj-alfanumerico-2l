                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"repositories\": [\"repo1\", \"repo2\"],\n  \"account\": \"minha-org\",\n  \"provider\": \"azure\",\n  \"analysis_method\": \"cloud\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/analyze",
              "host": ["{{baseUrl}}"],
              "path": ["analyze"]
