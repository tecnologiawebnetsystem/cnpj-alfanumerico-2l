<Window x:Class="CNPJAnalyzer.WPF.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="CNPJ Analyzer - Login" 
        Height="600" 
        Width="400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="NoResize">
    
    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="40">
            
            <!-- Logo -->
            <TextBlock Text="CNPJ Analyzer"
                      FontSize="32"
                      FontWeight="Bold"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,40"/>
            
            <!-- Email -->
            <TextBlock Text="Email"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      Margin="0,0,0,8"/>
            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                    Padding="12"
                    FontSize="14"
                    Margin="0,0,0,20"
                    materialDesign:HintAssist.Hint="seu@email.com"/>
            
            <!-- Password -->
            <TextBlock Text="Senha"
                      Foreground="{StaticResource TextSecondaryBrush}"
                      Margin="0,0,0,8"/>
            <PasswordBox x:Name="PasswordBox"
                        Padding="12"
                        FontSize="14"
                        Margin="0,0,0,10"/>
            
            <!-- Error Message -->
            <TextBlock Text="{Binding ErrorMessage}"
                      Foreground="{StaticResource ErrorColor}"
                      TextWrapping="Wrap"
                      Margin="0,0,0,20"
                      Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}"/>
            
            <!-- Login Button -->
            <Button Content="Entrar"
                   Style="{StaticResource PrimaryButton}"
                   Command="{Binding LoginCommand}"
                   Height="44"
                   Margin="0,10,0,0"/>
            
            <!-- Loading Indicator -->
            <ProgressBar IsIndeterminate="True"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                        Margin="0,20,0,0"/>
            
        </StackPanel>
    </Grid>
</Window>
