<Window x:Class="CNPJAnalyzer.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="CNPJ Analyzer" 
        Height="800" 
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource PrimaryHueDarkBrush}">
            <StackPanel>
                <!-- Logo/Header -->
                <Border Height="100" Background="{DynamicResource PrimaryHueMidBrush}">
                    <StackPanel VerticalAlignment="Center" Margin="20,0">
                        <TextBlock Text="CNPJ Analyzer" 
                                   FontSize="24" 
                                   FontWeight="Bold" 
                                   Foreground="White"/>
                        <TextBlock Text="{Binding CurrentUser.Email}" 
                                   FontSize="12" 
                                   Foreground="#B0BEC5"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Menu Items -->
                <ListBox Style="{StaticResource MaterialDesignNavigationListBox}"
                         Margin="0,20,0,0"
                         Background="Transparent"
                         Foreground="White">
                    
                    <ListBoxItem Content="Dashboard" 
                                 Command="{Binding NavigateToDashboardCommand}">
                        <ListBoxItem.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ViewDashboard" 
                                                            Width="24" 
                                                            Height="24" 
                                                            Margin="0,0,15,0"/>
                                    <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBoxItem.ContentTemplate>
                    </ListBoxItem>

                    <ListBoxItem Content="Análises" 
                                 Command="{Binding NavigateToAnalysesCommand}">
                        <ListBoxItem.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ChartLine" 
                                                            Width="24" 
                                                            Height="24" 
                                                            Margin="0,0,15,0"/>
                                    <TextBlock Text="Análises" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBoxItem.ContentTemplate>
                    </ListBoxItem>

                    <ListBoxItem Content="Desenvolvedores" 
                                 Command="{Binding NavigateToDevelopersCommand}"
                                 Visibility="{Binding CurrentUser.Role, Converter={StaticResource RoleToVisibilityConverter}, ConverterParameter=ADMIN_CLIENT}">
                        <ListBoxItem.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountGroup" 
                                                            Width="24" 
                                                            Height="24" 
                                                            Margin="0,0,15,0"/>
                                    <TextBlock Text="Desenvolvedores" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBoxItem.ContentTemplate>
                    </ListBoxItem>

                    <ListBoxItem Content="Tarefas" 
                                 Command="{Binding NavigateToTasksCommand}">
                        <ListBoxItem.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CheckboxMarkedCircleOutline" 
                                                            Width="24" 
                                                            Height="24" 
                                                            Margin="0,0,15,0"/>
                                    <TextBlock Text="Tarefas" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBoxItem.ContentTemplate>
                    </ListBoxItem>

                    <ListBoxItem Content="Contas" 
                                 Command="{Binding NavigateToAccountsCommand}"
                                 Visibility="{Binding CurrentUser.Role, Converter={StaticResource RoleToVisibilityConverter}, ConverterParameter=ADMIN_CLIENT}">
                        <ListBoxItem.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Connection" 
                                                            Width="24" 
                                                            Height="24" 
                                                            Margin="0,0,15,0"/>
                                    <TextBlock Text="Contas Conectadas" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBoxItem.ContentTemplate>
                    </ListBoxItem>

                    <ListBoxItem Content="Configurações" 
                                 Command="{Binding NavigateToSettingsCommand}">
                        <ListBoxItem.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Settings" 
                                                            Width="24" 
                                                            Height="24" 
                                                            Margin="0,0,15,0"/>
                                    <TextBlock Text="Configurações" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBoxItem.ContentTemplate>
                    </ListBoxItem>
                </ListBox>

                <!-- Logout Button -->
                <Button Content="Sair" 
                        Command="{Binding LogoutCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White"
                        Margin="20"
                        VerticalAlignment="Bottom">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Logout" 
                                                        Width="20" 
                                                        Height="20" 
                                                        Margin="0,0,10,0"/>
                                <TextBlock Text="Sair" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}"/>
    </Grid>
</Window>
